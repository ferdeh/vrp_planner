APP_NAME=vrp_dispatch_optimizer
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080
DATABASE_URL=postgresql+psycopg2://vrp_user:change_me@localhost:5432/vrp_planner
# Docker/container example:
# DATABASE_URL=postgresql+psycopg2://vrp_user:change_me@host.docker.internal:5432/vrp_planner
MASTER_DATA_API_BASE_URL=http://host.docker.internal:8000
MASTER_DATA_NODES_PATH=/nodes
NETWORK_EFFECTIVE_EDGES_PATH=/edges/effective
TRUCK_MASTER_DATA_API_BASE_URL=http://host.docker.internal:8002
TRUCK_MASTER_DATA_TRUCKS_PATH=/api/trucks
USE_MOCK_MASTER_DATA=false
SOLVER_MAX_SECONDS=30
SOLVER_FIRST_STRATEGY=PATH_CHEAPEST_ARC
SOLVER_LOCAL_SEARCH=GUIDED_LOCAL_SEARCH
EXTERNAL_API_TIMEOUT_SECONDS=10
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
