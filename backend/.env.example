APP_NAME=vrp_planner
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080
DATABASE_URL=postgresql+psycopg2://planner:change_me@planner-db:5432/vrp_planner
MASTER_DATA_API_BASE_URL=http://spbu-backend:8000
MASTER_DATA_NODES_PATH=/nodes
NETWORK_EFFECTIVE_EDGES_PATH=/edges/effective
TRUCK_MASTER_DATA_API_BASE_URL=http://truck-backend:8000
TRUCK_MASTER_DATA_TRUCKS_PATH=/api/trucks
USE_MOCK_MASTER_DATA=false
SOLVER_MAX_SECONDS=30
SOLVER_FIRST_STRATEGY=PATH_CHEAPEST_ARC
SOLVER_LOCAL_SEARCH=GUIDED_LOCAL_SEARCH
EXTERNAL_API_TIMEOUT_SECONDS=10
LOG_LEVEL=INFO
CORS_ORIGINS=http://planner.localhost:8088
PLANNER_PUBLIC_BASE_URL=http://planner.localhost:8088
PLANNER_AUTH_LOGOUT_URL=http://auth.localhost:8088/realms/vrp-platform/protocol/openid-connect/logout
PLANNER_OAUTH_CLIENT_ID=oauth2-proxy-planner
